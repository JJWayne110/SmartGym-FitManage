<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>

<VBox alignment="CENTER" spacing="25.0" style="-fx-pref-width: 350; -fx-pref-height: 400; -fx-background-color: #f4f4fc;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fitmanage.smartgym.controller.GymController">

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;" text="FitManage Telemetry System" />

    <VBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #ddd; -fx-border-radius: 8;">
        <HBox spacing="10.0">
            <Label style="-fx-font-weight: bold;" text="Temperatura:" />
            <Label fx:id="labelTemp" style="-fx-text-fill: #e74c3c;" text="0.0 °C" />
        </HBox>
        <HBox spacing="10.0">
            <Label style="-fx-font-weight: bold;" text="Humedad:" />
            <Label fx:id="labelHum" style="-fx-text-fill: #3498db;" text="0 %" />
        </HBox>
    </VBox>

    <Label fx:id="panelAlerta" alignment="CENTER" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 5; -fx-pref-width: 300; -fx-font-weight: bold;" text="ESTADO: NORMAL" />

    <Button fx:id="btnIniciar" onAction="#onIniciarClick" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-cursor: hand;" text="Iniciar Simulación">
        <textFill>
            <LinearGradient endX="1.0" endY="1.0">
                <stops>
                    <Stop>
                        <color>
                            <Color />
                        </color>
                    </Stop>
                    <Stop offset="1.0">
                        <color>
                            <Color red="1.0" green="1.0" blue="1.0" />
                        </color>
                    </Stop>
                </stops>
            </LinearGradient>
        </textFill></Button>

</VBox>
